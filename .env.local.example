# =============================================================================
# OPENAI (used by both the Realtime interview and the ADIN engine)
# The engine uses gpt-4o / gpt-4o-mini / o3-mini via the AI SDK.
# Get a key at platform.openai.com
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# WORLD ID (register at developer.worldcoin.org)
# =============================================================================
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-expertise

# =============================================================================
# SESSION (required in production, uses a default in development)
# Must be at least 32 characters
# =============================================================================
SESSION_SECRET=

# =============================================================================
# DATABASE (Neon PostgreSQL -- get a connection string at neon.tech)
# =============================================================================
DATABASE_URL=

# =============================================================================
# XMTP (wallet key for notification sender -- optional)
# =============================================================================
XMTP_PRIVATE_KEY=

# =============================================================================
# x402 (payment receiving -- real USDC on Base Sepolia)
# =============================================================================
X402_PAY_TO=0x...
X402_NETWORK=base-sepolia
FACILITATOR_URL=https://x402.org/facilitator

# =============================================================================
# DEMO MODE (set to "true" to enable World ID bypass in production)
# =============================================================================
NEXT_PUBLIC_DEMO_MODE=

# =============================================================================
# ADIN API KEY (required in production for v1 agent API access)
# =============================================================================
ADIN_API_KEY=
