# =============================================================================
# OPENAI (used by both the Realtime interview and the ADIN engine)
# The engine uses gpt-4o / gpt-4o-mini / o3-mini via the AI SDK.
# Get a key at platform.openai.com
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# WORLD ID (register at developer.worldcoin.org)
# =============================================================================
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-expertise

# =============================================================================
# XMTP (wallet key for notification sender)
# =============================================================================
XMTP_PRIVATE_KEY=

# =============================================================================
# x402 (payment receiving — real USDC on Base Sepolia)
# =============================================================================
X402_PAY_TO=0x...
X402_NETWORK=base-sepolia
FACILITATOR_URL=https://facilitator.x402.org
