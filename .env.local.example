# =============================================================================
# ADIN API (the backend — adin-chat deployed instance)
# =============================================================================
ADIN_API_URL=http://localhost:3001
ADIN_WALLET_ADDRESS=0x...

# =============================================================================
# OPENAI REALTIME (platform.openai.com — needs Realtime API access)
# =============================================================================
OPENAI_API_KEY=

# =============================================================================
# WORLD ID (register at developer.worldcoin.org)
# =============================================================================
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-expertise

# =============================================================================
# XMTP (wallet key for notification sender)
# =============================================================================
XMTP_PRIVATE_KEY=

# =============================================================================
# x402 (payment receiving)
# =============================================================================
X402_PAY_TO=0x...
X402_NETWORK=base-sepolia
